{
    "version": 4,
    "configurations": [
        {
            "name": "Launch C++ Debugger",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:python.interpreterPath}",
            "args": [
                "${file}"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        }
    ]
}